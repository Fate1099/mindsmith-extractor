{
  "manifest_version": 2,
  "name": "Mindsmith Markdown Extractor",
  "version": "1.3",
  "description": "Extracts Mindsmith lessons to Markdown",
  "browser_specific_settings": {
    "gecko": {
      "id": "{80cdfb9f-2129-4abe-b6e9-e30361767bd3}",
      "strict_min_version": "115.0"
    }
  },
  "permissions": [
    "https://app.mindsmith.ai/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://app.mindsmith.ai/*"],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "all_frames": true,
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": ["inject.js"],
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Mindsmith Extractor"
  }
}
